# LLM models (via LiteLLM — see https://docs.litellm.ai/docs/providers)
# Orchestrator: use a stronger model
ORCHESTRATOR_MODEL=vertex_ai/gemini-2.5-flash
# Specialists: use a faster/cheaper model
SPECIALIST_MODEL=vertex_ai/gemini-2.0-flash

# Google Cloud credentials (for Vertex AI / LiteLLM)
# Option A: service account key file path
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# Option B: set project + region directly (if running on GCP with Workload Identity)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Google Maps & Places APIs (single key works for both)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Feature flags
USE_LIVE_PLACES=false        # true = call Google Places live; false = use seeded JSON cache
ENV=development
